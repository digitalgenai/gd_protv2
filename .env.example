# --- Frontend (Vite) ---
# URL base da API Flask. Se o backend não estiver disponível, o front-end cai
# automaticamente para dados mockados.
VITE_API_BASE_URL=http://localhost:5000

# --- Backend (Flask) ---
# Obrigatório — sem isso o backend não sobe (ver backend/config.py).
DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/nome_do_banco
DB_SCHEMA=galpaodesign_teste

# Assina o cookie de sessão — defina um valor forte em qualquer ambiente real
# (o fallback em config.py é só pra dev local não travar).
SECRET_KEY=troque-por-um-valor-aleatorio-forte

# Origens autorizadas a chamar a API com cookies (separadas por vírgula). Precisa incluir
# toda origem real do front-end — dev (Vite), Docker/nginx, produção, etc.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8090

# Cookie de sessão só viaja em HTTPS quando true — deixe false em dev local (http puro) e
# mude pra true em qualquer ambiente real atrás de https.
SESSION_COOKIE_SECURE=false

# Base pública deste servidor Flask (usada para montar URLs de imagens locais).
PUBLIC_BASE_URL=http://localhost:5000

# --- Amazon S3 (imagens de produtos) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# --- EngajaCRM (EspoCRM) ---
ESPOCRM_BASE_URL=
ESPOCRM_API_KEY=

# --- Voz (webhook externo de transcrição — v2) ---
PROPOSTA_VOZ_WEBHOOK_SECRET=

# --- OpenAI (Whisper — v2) ---
OPENAI_API_KEY=
